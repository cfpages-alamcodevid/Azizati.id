{
  "name": "azizati-id",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "pages:dev": "npm run build && wrangler pages dev dist",
    "deploy:pages": "npm run build && wrangler pages deploy dist",
    "d1:migrate:local": "wrangler d1 execute AZIZATI_DB --local --file ./db/schema.sql",
    "d1:migrate:remote": "wrangler d1 execute AZIZATI_DB --remote --file ./db/schema.sql"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.6.0",
    "zustand": "^5.0.4"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.4.1",
    "vite": "^5.4.19",
    "wrangler": "^4.13.2"
  }
}
